<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= prop.bhk %> in <%= prop.location %> | PropBot</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-slide-up {
            animation: slideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
    </style>
</head>
<body class="bg-white text-slate-800 font-sans antialiased selection:bg-blue-200 min-h-screen flex flex-col">

    <nav class="p-6">
        <div class="max-w-5xl mx-auto">
            <a href="/listings" class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors">
                <span class="mr-2">←</span> Back to properties
            </a>
        </div>
    </nav>

    <main class="flex-grow max-w-5xl mx-auto px-4 sm:px-6 w-full animate-slide-up">
        
        <div class="rounded-3xl overflow-hidden h-[40vh] md:h-[60vh] bg-slate-100 mb-8 shadow-sm relative group">
            <% if (prop.mediaUrls && prop.mediaUrls.length > 0) { %>
                
                <div class="w-full h-full relative">
                    <% prop.mediaUrls.forEach((url, index) => { %>
                        <div class="carousel-item absolute inset-0 transition-opacity duration-700 ease-in-out <%= index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0' %>">
                            <img src="/proxy-media?url=<%= encodeURIComponent(url) %>" alt="Property View <%= index + 1 %>" class="w-full h-full object-cover">
                        </div>
                    <% }) %>
                </div>

                <% if (prop.mediaUrls.length > 1) { %>
                    <button onclick="prevSlide()" class="absolute left-4 top-1/2 -translate-y-1/2 z-20 bg-white/70 hover:bg-white text-slate-800 p-3 rounded-full shadow-lg backdrop-blur-md opacity-0 group-hover:opacity-100 transition-all duration-300 focus:outline-none hover:scale-110">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg>
                    </button>
                    
                    <button onclick="nextSlide()" class="absolute right-4 top-1/2 -translate-y-1/2 z-20 bg-white/70 hover:bg-white text-slate-800 p-3 rounded-full shadow-lg backdrop-blur-md opacity-0 group-hover:opacity-100 transition-all duration-300 focus:outline-none hover:scale-110">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
                    </button>

                    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex gap-2 bg-black/20 px-3 py-2 rounded-full backdrop-blur-sm">
                        <% prop.mediaUrls.forEach((_, index) => { %>
                            <button onclick="goToSlide(<%= index %>)" class="carousel-dot h-2 rounded-full transition-all duration-300 <%= index === 0 ? 'bg-white w-6' : 'bg-white/50 w-2 hover:bg-white/80' %>"></button>
                        <% }) %>
                    </div>
                    
                    <script>
                        let currentSlide = 0;
                        const slides = document.querySelectorAll('.carousel-item');
                        const dots = document.querySelectorAll('.carousel-dot');
                        const totalSlides = <%= prop.mediaUrls.length %>;

                        function updateCarousel() {
                            // Update Images
                            slides.forEach((slide, index) => {
                                if (index === currentSlide) {
                                    slide.classList.replace('opacity-0', 'opacity-100');
                                    slide.classList.replace('z-0', 'z-10');
                                } else {
                                    slide.classList.replace('opacity-100', 'opacity-0');
                                    slide.classList.replace('z-10', 'z-0');
                                }
                            });
                            
                            // Update Dots (Expand active dot to w-6, shrink others to w-2)
                            dots.forEach((dot, index) => {
                                if (index === currentSlide) {
                                    dot.classList.remove('bg-white/50', 'w-2');
                                    dot.classList.add('bg-white', 'w-6');
                                } else {
                                    dot.classList.remove('bg-white', 'w-6');
                                    dot.classList.add('bg-white/50', 'w-2');
                                }
                            });
                        }

                        function nextSlide() {
                            currentSlide = (currentSlide + 1) % totalSlides;
                            updateCarousel();
                        }

                        function prevSlide() {
                            currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
                            updateCarousel();
                        }

                        function goToSlide(index) {
                            currentSlide = index;
                            updateCarousel();
                        }
                    </script>
                <% } %>

            <% } else { %>
                <div class="w-full h-full flex flex-col items-center justify-center text-slate-400">
                    <span class="text-6xl mb-4">🏠</span>
                    <p>No images available for this property.</p>
                </div>
            <% } %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 pb-20">
            
            <div class="md:col-span-2">
                <div class="flex items-center gap-3 mb-4">
                    <span class="px-3 py-1 bg-slate-100 text-xs font-bold text-slate-600 rounded-full uppercase tracking-wide"><%= prop.listingType %></span>
                    <span class="text-sm font-medium text-slate-400">ID: <%= prop.shortId %></span>
                </div>
                
                <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-4 tracking-tight"><%= prop.bhk %> in <%= prop.location %></h1>
                
                <div class="prose prose-lg text-slate-600 mb-10">
                    <p class="leading-relaxed"><%= prop.description %></p>
                </div>

                <div class="grid grid-cols-2 gap-6 pt-8 border-t border-slate-100">
                    <div>
                        <p class="text-sm text-slate-400 mb-1">Furnishing</p>
                        <p class="text-lg font-medium text-slate-900"><%= prop.furnishing || "Not specified" %></p>
                    </div>
                    <div>
                        <p class="text-sm text-slate-400 mb-1">Location</p>
                        <p class="text-lg font-medium text-slate-900"><%= prop.location %></p>
                    </div>
                </div>
            </div>

            <div class="md:col-span-1 relative">
                <div class="sticky top-10 bg-slate-50 border border-slate-100 rounded-2xl p-6 shadow-sm">
                    <p class="text-sm text-slate-500 font-medium mb-1">Price</p>
                    <p class="text-4xl font-extrabold text-slate-900 mb-6">₹<%= prop.price.toLocaleString('en-IN') %><span class="text-lg text-slate-500 font-normal"><%= prop.listingType.toLowerCase() === 'rent' || prop.listingType.toLowerCase() === 'lease' ? '/mo' : '' %></span></p>
                    
                    <a href="https://wa.me/<%= prop.whatsappNumber.replace('whatsapp:', '').replace('+', '') %>?text=Hi! I am interested in property <%= prop.shortId %> (<%= prop.bhk %> in <%= prop.location %>)." 
                       target="_blank"
                       class="w-full flex justify-center items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-bold py-4 px-6 rounded-xl transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5">
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                        Chat with Owner
                    </a>
                    <p class="text-xs text-center text-slate-400 mt-4">Replies instantly via PropBot</p>
                </div>
            </div>
        </div>
    </main>
</body>
</html>