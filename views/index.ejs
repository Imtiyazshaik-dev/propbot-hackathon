<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PropBot | Live Marketplace</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fadeIn 0.6s ease-out forwards;
            opacity: 0;
        }
        /* Stagger the animations so cards load one after another */
        .card-1 { animation-delay: 0.1s; }
        .card-2 { animation-delay: 0.2s; }
        .card-3 { animation-delay: 0.3s; }
        .card-4 { animation-delay: 0.4s; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 font-sans antialiased selection:bg-blue-200">

    <nav class="bg-white shadow-sm border-b border-slate-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-2">
                    <span class="text-2xl">🤖</span>
                    <span class="font-bold text-xl tracking-tight text-slate-900">PropBot<span class="text-blue-600">.</span></span>
                </div>
                <div>
                    <a href="https://wa.me/17754298779" class="text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors">List a Property →</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900 mb-4">Find your next home.</h1>
        <p class="text-lg text-slate-500 max-w-2xl">Browse verified properties instantly uploaded by top brokers via WhatsApp. No fake listings, just real homes.</p>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            
            <% if (properties.length === 0) { %>
                <div class="col-span-full text-center py-20">
                    <span class="text-4xl block mb-4">🏜️</span>
                    <h3 class="text-xl font-medium text-slate-600">No properties available right now.</h3>
                    <p class="text-slate-400">Tell your broker to send some photos to the bot!</p>
                </div>
            <% } else { %>
                <% properties.forEach((prop, index) => { %>
                    <a href="/property/<%= prop.shortId %>" class="block group animate-fade-in card-<%= (index % 4) + 1 %>">
                        <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-100 transition-all duration-300 group-hover:shadow-xl group-hover:-translate-y-1">
                            
                            <div class="relative h-64 w-full bg-slate-200 overflow-hidden">
                                <% if (prop.mediaUrls && prop.mediaUrls.length > 0) { %>
                                    <img src="/proxy-media?url=<%= encodeURIComponent(prop.mediaUrls[0]) %>" alt="Property Image" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                                <% } else { %>
                                    <div class="w-full h-full flex items-center justify-center text-slate-400">
                                        <span class="text-4xl">📸</span>
                                    </div>
                                <% } %>
                                <div class="absolute top-4 left-4 flex gap-2">
                                    <span class="px-3 py-1 bg-white/90 backdrop-blur-sm text-xs font-bold text-slate-900 rounded-full shadow-sm uppercase tracking-wide"><%= prop.listingType %></span>
                                </div>
                            </div>

                            <div class="p-6">
                                <div class="flex justify-between items-start mb-2">
                                    <h2 class="text-xl font-bold text-slate-900"><%= prop.bhk %></h2>
                                    <p class="text-lg font-bold text-blue-600">₹<%= prop.price.toLocaleString('en-IN') %><span class="text-sm text-slate-500 font-normal"><%= prop.listingType.toLowerCase() === 'rent' || prop.listingType.toLowerCase() === 'lease' ? '/mo' : '' %></span></p>
                                </div>
                                <div class="flex items-center text-slate-500 text-sm mb-4">
                                    <span>📍 <%= prop.location %></span>
                                </div>
                                <p class="text-slate-600 text-sm line-clamp-2 leading-relaxed">
                                    <%= prop.description %>
                                </p>
                            </div>
                            
                            <div class="px-6 py-4 border-t border-slate-100 bg-slate-50 flex justify-between items-center group-hover:bg-blue-50 transition-colors">
                                <span class="text-sm font-medium text-slate-500 group-hover:text-blue-600">View Details</span>
                                <span class="text-slate-400 group-hover:text-blue-600 transition-transform group-hover:translate-x-1">→</span>
                            </div>
                        </div>
                    </a>
                <% }) %>
            <% } %>

        </div>
    </div>

</body>
</html>